# Copy this file to .env and fill in the values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.5wn4f6n.mongodb.net/?appName=Cluster0
DATABASE_NAME=pantrymind

# Spoonacular API
SPOONACULAR_API_KEY=your_spoonacular_key
SPOONACULAR_BASE_URL=https://api.spoonacular.com

# Groq LLM (FREE)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Meal Planning Settings
DEFAULT_MEALS_PER_DAY=1
DEFAULT_DIET_TYPE=standard
DEFAULT_SERVINGS=1
EXPIRY_WARNING_DAYS=7
MIN_INGREDIENT_MATCH_PERCENTAGE=50

# Cache Settings
RECIPE_CACHE_SIZE=100
RECIPE_CACHE_TTL=86400  # 24 hours